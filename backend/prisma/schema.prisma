// Prisma schema — Property Maintenance Fund Allocation DSS
// Datasource: PostgreSQL (Neon or any Postgres instance)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//  Enums

enum Role {
  ADMIN
  MANAGER
}

enum PropertyType {
  RESIDENTIAL
  APARTMENT
  COMMERCIAL
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
}

enum Category {
  ROOFING
  STRUCTURAL
  ELECTRICAL
  PLUMBING
  HVAC
  FLOORING
  PAINTING
  SECURITY
  LANDSCAPING
  OTHER
}

enum RequestStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  DEFERRED
  REJECTED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

//  Models

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(MANAGER)
  createdAt    DateTime @default(now())

  // Relations (audit trail — who created/requested/allocated)
  propertiesCreated  Property[]            @relation("PropertyCreatedBy")
  requestsCreated    MaintenanceRequest[]  @relation("RequestRequestedBy")
  requestsReviewed   MaintenanceRequest[]  @relation("RequestReviewedBy")
  allocationsMade    FundAllocation[]      @relation("AllocationBy")
  adjustmentsMade    FundAdjustment[]      @relation("AdjustmentBy")

  // Manager <-> Property assignment (many-to-many via join table)
  managedProperties  PropertyAssignment[]  @relation("AssignmentManager")
  assignmentsMade    PropertyAssignment[]  @relation("AssignmentAssignedBy")

  @@map("users")
}

model Property {
  id           String         @id @default(uuid())
  name         String
  address      String
  propertyType PropertyType
  units        Int            @default(1)
  yearBuilt    Int?
  totalAreaSqm Decimal?       @db.Decimal(10, 2)
  description  String?
  status       PropertyStatus @default(ACTIVE)

  createdById  String?
  createdBy    User?          @relation("PropertyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  requests    MaintenanceRequest[]
  funds       MaintenanceFund[]
  assignments PropertyAssignment[]

  @@map("properties")
}

// Join table: which manager(s) are assigned to which propert(y/ies).
// Modelled many-to-many so a manager could one day cover more than one
// property (or a property have a backup manager) without a schema change,
// even though the common case demoed here is one manager per property.
model PropertyAssignment {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  managerId  String
  manager    User     @relation("AssignmentManager", fields: [managerId], references: [id], onDelete: Cascade)

  assignedById String?
  assignedBy   User?    @relation("AssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([propertyId, managerId])
  @@index([propertyId])
  @@index([managerId])
  @@map("property_assignments")
}

model MaintenanceRequest {
  id              String        @id @default(uuid())
  propertyId      String
  property        Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  category        Category
  severity        Severity?     // manager-facing label; maps server-side to urgency/impact/assetImportance
  safetyHazard    Boolean       @default(false)
  urgency         Int           // 1 = low … 10 = critical
  impact          Int           // safety / value impact, 1–10
  assetImportance Int           // 1–10
  estimatedCost   Decimal       @db.Decimal(12, 2)
  status          RequestStatus @default(PENDING)
  priorityScore   Decimal?      @db.Decimal(6, 2) // computed by the DSS engine

  requestedById   String?
  requestedBy     User?         @relation("RequestRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  assignedTo      String?
  notes           String?

  rejectionReason String?
  reviewedById    String?
  reviewedBy      User?         @relation("RequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  allocations FundAllocation[]

  @@index([propertyId])
  @@index([status])
  @@map("maintenance_requests")
}

model MaintenanceFund {
  id              String   @id @default(uuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  totalAmount     Decimal  @default(0) @db.Decimal(12, 2)
  allocatedAmount Decimal  @default(0) @db.Decimal(12, 2)
  periodLabel     String   // e.g. "Q1 2026"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  allocations FundAllocation[]

  @@index([propertyId])
  @@map("maintenance_funds")
}

model FundAllocation {
  id             String   @id @default(uuid())
  fundId         String
  fund           MaintenanceFund @relation(fields: [fundId], references: [id], onDelete: Cascade)
  requestId      String
  request        MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  amountAssigned  Decimal  @db.Decimal(12, 2)
  // What the DSS recommended at the moment of approval (usually the request's
  // estimatedCost). Kept separately so later top-ups can be compared against
  // the original system suggestion, e.g. "DSS suggested ₦200,000; ₦250,000 released".
  suggestedAmount Decimal? @db.Decimal(12, 2)
  allocationDate  DateTime @default(now())

  allocatedById  String?
  allocatedBy    User?    @relation("AllocationBy", fields: [allocatedById], references: [id], onDelete: SetNull)
  notes          String?

  adjustments FundAdjustment[]

  @@index([fundId])
  @@index([requestId])
  @@map("fund_allocations")
}

// Audit trail for "Adjust Funds": every time an admin tops up (or reduces)
// an already-approved allocation after ground-truth costs turn out different
// from the original estimate.
model FundAdjustment {
  id             String         @id @default(uuid())
  allocationId   String
  allocation     FundAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  previousAmount Decimal  @db.Decimal(12, 2)
  newAmount      Decimal  @db.Decimal(12, 2)
  reason         String

  adjustedById   String?
  adjustedBy     User?    @relation("AdjustmentBy", fields: [adjustedById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([allocationId])
  @@map("fund_adjustments")
}
