# ----------------------------------------------------------------
# Backend environment variables — copy this file to ".env" and fill in
# ----------------------------------------------------------------

# PostgreSQL connection string. Pick one:
#   Local Postgres (e.g. Homebrew):
#     postgresql://YOUR_USER@localhost:5432/property_dss?schema=public
#   Hosted (free) at https://neon.tech — needs ?sslmode=require:
#     postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/property_dss?schema=public"

# Secret used to sign JWT auth tokens. Use a long random string in production.
JWT_SECRET="change-this-to-a-long-random-string"

# How long a login token stays valid.
JWT_EXPIRES_IN="7d"

# Port the API server listens on.
PORT=4000

# The frontend origin allowed to call this API (CORS).
CORS_ORIGIN="http://localhost:3000"

# ----------------------------------------------------------------
# Optional: credentials used by the database seed (npm run seed).
# The seed creates the initial ADMIN account. Set these, then change
# the passwords after first login. If left unset, the seed uses
# obvious placeholder passwords that you MUST change.
# ----------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me-admin"
SEED_MANAGER_EMAIL="manager@example.com"
SEED_MANAGER_PASSWORD="change-me-manager"
